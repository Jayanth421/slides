# Runtime
NODE_ENV=development
PORT=5000
# Optional: choose a specific file at startup (examples: .env.local, .env.aws)
# ENV_FILE=.env.local
# Optional: override Node's DNS servers (helpful if DNS lookups fail with ECONNREFUSED)
# DNS_SERVERS=8.8.8.8,1.1.1.1
# DNS_FALLBACK_SERVERS=8.8.8.8,1.1.1.1
# Optional: serve the built frontend from the backend (requires ../frontend/dist)
# SERVE_FRONTEND=true

# URLs and CORS
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
# Optional explicit frontend URL used inside smartboard QR links (recommended in production)
# SMARTBOARD_ACTION_BASE_URL=https://your-frontend-domain.com

# MongoDB
# If your password contains special characters (example: "@"), URL-encode it (example: "%40").
MONGO_URI=mongodb+srv://<user>:<url_encoded_password>@<cluster-host>.mongodb.net/cmr_smart_portal?retryWrites=true&w=majority&appName=<appName>
# Optional: extra fallback URI if primary fails
MONGO_FALLBACK_URI=

# JWT
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=30d
# Optional (used for local upload tokens)
# JWT_UPLOAD_SECRET=replace_with_long_random_upload_secret
JWT_UPLOAD_EXPIRES=15m

# Storage provider: "s3" (default) or "local"
STORAGE_PROVIDER=s3
# When STORAGE_PROVIDER=s3:
# - presigned: browser uploads directly to S3 (requires S3 bucket CORS for your frontend origin)
# - proxy: browser uploads to backend, backend streams to S3 (avoids browser S3 CORS issues)
S3_UPLOAD_MODE=presigned
# Used when STORAGE_PROVIDER=local (relative to backend root)
LOCAL_UPLOAD_DIR=uploads
# 60MB default max
LOCAL_UPLOAD_MAX_BYTES=62914560

# OTP and QR
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
SMARTBOARD_QR_EXPIRES_MINUTES=4

# Mail (Node transporter)
MAIL_PROVIDER=node
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=20
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=CMR Smart Portal <support@example.com>

# Optional when MAIL_PROVIDER=python
PYTHON_BIN=python3
PYTHON_MAIL_SCRIPT=scripts/send_mail.py

# AWS storage
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=cmrcet-ppt-2026
CLOUDFRONT_URL=https://d6ycqdk4s02gp.cloudfront.net


# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
# Set true only if you want strict login rate-limiting in local development
ENABLE_DEV_LOGIN_RATE_LIMIT=false
# Development CORS is open by default. Set true to enforce CORS_ORIGINS strictly in dev.
STRICT_DEV_CORS=false
